############################################
# AuditDiff Environment Configuration
############################################

############################################
# SERVER CONFIG
############################################

PORT=3000
NODE_ENV=development

############################################
# BLOCKCHAIN SCANNER (Module 3)
############################################

ETHERSCAN_API_KEY=your_etherscan_api_key_here
ETH_RPC_URL=https://mainnet.infura.io/v3/YOUR_INFURA_KEY

############################################
# DATABASE (Module 5)
############################################

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/auditdiff

DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=auditdiff

############################################
# ADDRESS INTELLIGENCE (Module 6)
############################################

CACHE_TTL_MS=300000
ENABLE_EXPLOIT_DB=true
ENABLE_LABELS=true

############################################
# RULE ENGINE (Module 4)
############################################

RISK_SCORE_THRESHOLD=7
ENABLE_COMBO_DETECTION=true

############################################
# ELECTRON APP
############################################

ELECTRON_DEVTOOLS=true
FRONTEND_URL=http://localhost:5173

############################################
# LOGGING / DEBUG
############################################

LOG_LEVEL=debug
ENABLE_DEBUG_LOGS=true
